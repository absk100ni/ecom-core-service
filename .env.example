# ==================== CORE ====================
PORT=8080
ENVIRONMENT=production          # "development" or "production"
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/ecom?retryWrites=true&w=majority
MONGO_DB=ecom

# ==================== SECURITY ====================
JWT_SECRET=change-me-to-a-strong-random-string-64-chars
CORS_ORIGINS=https://yourstore.com,https://admin.yourstore.com

# ==================== LOGGING (Grafana/Loki) ====================
LOG_LEVEL=info                  # debug, info, warn, error
LOG_FORMAT=json                 # "json" for Grafana/Loki, "text" for local dev

# ==================== AUTH (OTP) ====================
OTP_SERVICE=mock                # "mock" for dev, "msg91" for production
MSG91_AUTH_KEY=                  # Get from msg91.com → Developers → API Keys
MSG91_TEMPLATE_ID=              # Get from msg91.com → OTP → Templates

# ==================== PAYMENTS ====================
PAYMENT_GATEWAY=razorpay        # "razorpay" or "cashfree"

# Razorpay (dashboard.razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cashfree (merchant.cashfree.com → Developers → API Keys)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox            # "sandbox" or "production"

# ==================== SHIPPING ====================
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ==================== STORAGE ====================
S3_BUCKET=                      # AWS S3 bucket for product images
S3_REGION=ap-south-1

# ==================== NOTIFICATIONS ====================
NOTIFICATION_SERVICE_URL=http://localhost:9090
